# ── Alpaca Paper Trading ─────────────────────────────────────────────────────
# 1. Go to https://app.alpaca.markets
# 2. Click "Paper Trading" in the left sidebar
# 3. Go to "API Keys" and generate a new key pair
# 4. Paste them below (paper keys are different from live keys!)
ALPACA_API_KEY=your_alpaca_paper_api_key_here
ALPACA_SECRET_KEY=your_alpaca_paper_secret_key_here

# Paper trading uses Alpaca's simulated environment (no real money)
# Default starting balance is $100,000 — already set by Alpaca
PAPER_TRADING=true

# ── Anthropic / Claude ───────────────────────────────────────────────────────
# 1. Go to https://console.anthropic.com
# 2. Click "API Keys" → "Create Key"
# 3. Paste it below
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Bot Settings (safe defaults — change later if needed) ────────────────────
# Minutes between each analysis + trading cycle
CHECK_INTERVAL_MINUTES=60

# Max USD to spend on a single trade
MAX_POSITION_SIZE_USD=2000

# Max number of open positions at the same time
MAX_TOTAL_POSITIONS=10

# Stocks to always monitor (prices sent to Claude every cycle)
WATCHLIST=AAPL,MSFT,GOOGL,AMZN,NVDA,TSLA,META,SPY,QQQ

# ── Telegram notifications ────────────────────────────────────────────────────
# The bot sends a short summary after every trading cycle.
# Setup:
#   1. Open Telegram and message @BotFather → /newbot → follow the steps.
#      Copy the token it gives you and paste below.
#   2. Start a chat with your new bot, then open this URL in your browser:
#      https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#      Send any message to your bot first, then refresh the URL.
#      Find "chat" → "id" in the JSON — that is your TELEGRAM_CHAT_ID.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
